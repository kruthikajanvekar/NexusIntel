# Example environment variables for NexusIntel

# Secret key used to sign JWT tokens. Replace with a secure random value in production.
SECRET_KEY=replace_this_with_a_real_secret_key

# Base URL of the API (used only by the Streamlit dashboard).
# If you deploy dashboard separately from the backend, set this accordingly.
#API_BASE_URL=https://your-railway-service-url.com
